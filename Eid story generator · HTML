            if (difficulty === 'simple') {
                difficultyInstructions = 'استخدم جملاً قصيرة ومباشرة، وكلمات بسيطة.';
            } else if (difficulty === 'moderate') {
                difficultyInstructions = 'استخدم جملاً متوسطة بأسلوب واضح.';
            } else {
                difficultyInstructions = 'استخدم أسلوباً أدبياً جميلاً مع تنوع في التعابير.';
            }

            return `اكتب بطاقة معايدة دافئة وشخصية بمناسبة عيد الأضحى ${genderText} ${name}.

المواصفات:
- المستوى اللغوي: ${difficulty === 'simple' ? 'بسيط' : difficulty === 'moderate' ? 'متوسط' : 'متقدم'}
