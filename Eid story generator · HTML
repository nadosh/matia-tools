        // بناء برومبت القصة
        function buildStoryPrompt(name, gender, difficulty, values, details) {
            const genderText = gender === 'male' ? 'طالب' : 'طالبة';
            const pronouns = gender === 'male' ? 
                { he: 'هو', his: 'له', him: 'ه' } : 
                { he: 'هي', his: 'لها', him: 'ها' };

            let difficultyInstructions = '';
            if (difficulty === 'simple') {
                difficultyInstructions = 'استخدم جملاً قصيرة جداً (5-8 كلمات)، ومفردات بسيطة، وأفكاراً مباشرة. مناسب للمرحلة الابتدائية المبكرة أو ذوي الصعوبات اللغوية.';
            } else if (difficulty === 'moderate') {
                difficultyInstructions = 'استخدم جملاً متوسطة الطول، ومفردات مألوفة، وأفكاراً واضحة مع بعض التفاصيل. مناسب للمرحلة الابتدائية العليا.';
            } else {
                difficultyInstructions = 'استخدم جملاً أطول مع تفاصيل أكثر، ومفردات متنوعة، وأسلوب أدبي بسيط. مناسب للمرحلة الإعدادية.';
            }

            let valuesText = values.length > 0 ? 
                `ركز على القيم التالية: ${values.join('، ')}.` : 
                'ركز على قيم عيد الأضحى الأساسية.';

            let detailsText = details ? `تفاصيل إضافية عن الطالب: ${details}` : '';

            return `اكتب قصة قصيرة عن عيد الأضحى المبارك لـ${genderText} اسم${pronouns.his} ${name}.

المواصفات:
- المستوى اللغوي: ${difficulty === 'simple' ? 'بسيط جداً' : difficulty === 'moderate' ? 'متوسط' : 'متقدم'}
- ${difficultyInstructions}
- ${valuesText}
${detailsText ? '- ' + detailsText : ''}

القصة يجب أن:
1. تكون مناسبة لطلاب التربية الخاصة
2. تحتوي على أحداث إيجابية ومفرحة
3. تعلم قيماً تربوية بطريقة غير مباشرة
4. تكون بطول 8-12 جملة تقريباً (حسب المستوى)
5. تستخدم اسم الطالب في القصة عدة مرات

ابدأ القصة مباشرة بدون مقدمات.`;
        }

        // بناء برومبت البطاقة
        function buildCardPrompt(name, gender, difficulty, values, details) {
            const genderText = gender === 'male' ? 'للطالب' : 'للطالبة';
            const pronouns = gender === 'male' ? 
                { you: 'أنت', your: 'لك', youAdj: 'أيها', blessing: 'بارك الله فيك' } : 
                { you: 'أنتِ', your: 'لكِ', youAdj: 'أيتها', blessing: 'بارك الله فيكِ' };

